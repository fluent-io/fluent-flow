# PostgreSQL connection string
DATABASE_URL=postgres://fluentflow:password@postgres:5432/fluentflow

# GitHub personal access token (needs: repo, read:org, project scopes)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Secret used to verify GitHub webhook payloads
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# HTTP port to listen on
PORT=3847

# Config cache TTL in milliseconds (default: 5 minutes)
CONFIG_CACHE_TTL_MS=300000

# Postgres password (used by docker-compose)
POSTGRES_PASSWORD=password

# MCP authentication token (for AI agent access to /mcp endpoint)
MCP_AUTH_TOKEN=

# Agent transport tokens (referenced by token_env in config/agents.yml)
# Add one env var per agent that uses token-based auth
OPENCLAW_WEBHOOK_TOKEN=
